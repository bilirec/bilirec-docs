---
interface CardItem {
	icon: string;
	title: string;
	description: string;
	href: string;
}

interface Props {
	items: CardItem[];
	columnsClass?: string;
	titleClass?: string;
	cardClass?: string;
}

const {
	items,
	columnsClass = 'md:grid-cols-2',
	titleClass = 'text-lg',
	cardClass = '',
} = Astro.props as Props;
---

<div class:list={['not-content grid gap-4', columnsClass]}>
	{
		items.map((item) => (
			<a
				href={item.href}
				class:list={['icon-link-card group px-5 py-4', cardClass]}
			>
				<div class="flex flex-col gap-1.5">
					<div class="flex items-center gap-2">
						<span class="icon-link-card__icon">{item.icon}</span>
						<div class:list={['font-semibold leading-6', titleClass]}>{item.title}</div>
					</div>
					<p class="icon-link-card__description pl-7.5 m-0 text-sm">{item.description}</p>
				</div>
			</a>
		))
	}
</div>
